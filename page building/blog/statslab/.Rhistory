scale_y_continuous(labels = scales::percent_format()) +
# 축, 제목, 범례 레이블 설정
labs(
title = "성별에 따른 임금 차별 발생 빈도 인식",
subtitle = "동일한 일을 하고도 여성이 남성보다 적은 임금을 받는 경우",
x = "응답자 성별",
y = "비율 (%)",
fill = "응답 범주"
) +
theme_minimal() +
theme(
text = element_text(family = "Malgun Gothic"), # Mac 사용자는 "AppleGothic"
plot.title = element_text(face = "bold", size = 15, hjust = 0.5),
plot.subtitle = element_text(size = 11, hjust = 0.5, color = "gray40"),
legend.position = "right", # 범례를 오른쪽에 배치
axis.text = element_text(size = 11)
)
# 1. 그래프를 그리는 사용자 정의 함수 만들기
# 변수명(var_name)과 부제목(subtitle_text)을 입력받아 그래프를 반환하는 함수입니다.
plot_gender_stacked <- function(df, var_name, subtitle_text) {
# 데이터 전처리
plot_df <- df %>%
# 입력받은 변수의 유효 응답만 필터링
filter(.data[[var_name]] > 0) %>%
mutate(
label_var = factor(.data[[var_name]],
levels = c(1, 2, 3, 4, 5),
labels = c("전혀 없다", "드물게 있다", "때때로 있다", "자주 있다", "항상 있다"))
) %>%
group_by(sex_label, label_var) %>%
summarise(weighted_n = sum(finalwt, na.rm = TRUE), .groups = "drop_last") %>%
mutate(percent = weighted_n / sum(weighted_n)) %>%
ungroup()
# 시각화
p <- ggplot(plot_df, aes(x = sex_label, y = percent, fill = label_var)) +
geom_bar(stat = "identity", position = "fill", width = 0.5, color = "black", alpha = 0.9) +
geom_text(aes(label = scales::percent(percent, accuracy = 0.1)),
position = position_fill(vjust = 0.5),
size = 4, fontface = "bold", color = "black") +
scale_fill_brewer(palette = "Set1") +
scale_y_continuous(labels = scales::percent_format()) +
labs(
title = "성별에 따른 상황별 발생 빈도 인식",
subtitle = subtitle_text, # 입력받은 부제목 사용
x = "응답자 성별",
y = "비율 (%)",
fill = "응답 범주"
) +
theme_minimal() +
theme(
text = element_text(family = "Malgun Gothic"), # Mac은 "AppleGothic"
plot.title = element_text(face = "bold", size = 15, hjust = 0.5),
plot.subtitle = element_text(size = 11, hjust = 0.5, color = "gray40"),
legend.position = "right",
axis.text = element_text(size = 11)
)
return(p)
}
# (1) manipowr
p1 <- plot_gender_stacked(df_clean, "manipowr", "여성이 남성을 조종하여 권력을 얻는 경우")
print(p1) # 그래프 창에 출력
# (2) getoffnd
p2 <- plot_gender_stacked(df_clean, "getoffnd", "여성이 손쉽게 불쾌감을 느끼는 경우")
print(p2)
# (3) paidless
p3 <- plot_gender_stacked(df_clean, "paidless", "동일한 일을 하고도 여성이 남성보다 적은 임금을 받는 경우")
print(p3)
# (4) exasxhar
p4 <- plot_gender_stacked(df_clean, "exasxhar", "여성이 직장에서 성희롱을 과장해서 보고하는 경우")
print(p4)
