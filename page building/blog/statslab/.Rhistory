# 1. 데이터 전처리 및 성별/범주별 비율 계산
plot_df <- df_clean %>%
# -1(해당 없음)과 -8(모름/무응답)을 제외하고 유효한 응답(1~5)만 남기기
filter(paidless > 0) %>%
# 범주형(Factor) 변수로 변환 및 라벨 부여
mutate(
paidless_label = factor(paidless,
levels = c(1, 2, 3, 4, 5),
labels = c("전혀 없다", "드물게 있다", "때때로 있다", "자주 있다", "항상 있다"))
) %>%
# 성별과 응답 범주를 기준으로 그룹화
group_by(sex_label, paidless_label) %>%
# 가중치가 적용된 응답자 수 합산 (가중치를 안 쓴다면 sum(weight_var) 대신 n() 사용)
summarise(weighted_n = sum(weight_var, na.rm = TRUE), .groups = "drop_last") %>%
# 각 성별 그룹 내에서 해당 범주가 차지하는 비율(%) 계산
mutate(percent = weighted_n / sum(weighted_n)) %>%
ungroup()
# 1. 데이터 전처리 및 성별/범주별 비율 계산
plot_df <- df_clean %>%
# -1(해당 없음)과 -8(모름/무응답)을 제외하고 유효한 응답(1~5)만 남기기
filter(paidless > 0) %>%
# 범주형(Factor) 변수로 변환 및 라벨 부여
mutate(
paidless_label = factor(paidless,
levels = c(1, 2, 3, 4, 5),
labels = c("전혀 없다", "드물게 있다", "때때로 있다", "자주 있다", "항상 있다"))
) %>%
# 성별과 응답 범주를 기준으로 그룹화
group_by(sex_label, paidless_label) %>%
# 가중치가 적용된 응답자 수 합산 (가중치를 안 쓴다면 sum(weight_var) 대신 n() 사용)
summarise(weighted_n = sum(finalwt, na.rm = TRUE), .groups = "drop_last") %>%
# 각 성별 그룹 내에서 해당 범주가 차지하는 비율(%) 계산
mutate(percent = weighted_n / sum(weighted_n)) %>%
ungroup()
# 2. 100% Stacked Bar Graph (누적 막대 그래프) 시각화
ggplot(plot_df, aes(x = sex_label, y = percent, fill = paidless_label)) +
# 누적 막대 그래프 그리기 (position = "fill"이 100% 기준으로 맞춰줍니다)
geom_bar(stat = "identity", position = "fill", width = 0.5, color = "black", alpha = 0.9) +
# 막대 중앙에 퍼센트 텍스트 추가
geom_text(aes(label = scales::percent(percent, accuracy = 0.1)), # 소수점 1자리까지 표시
position = position_fill(vjust = 0.5),
size = 4, fontface = "bold", color = "white") +
# 색상 팔레트 설정 (원하시는 색상으로 변경 가능)
scale_fill_brewer(palette = "Set2") +
# y축을 백분율(0~100%) 형태로 표시
scale_y_continuous(labels = scales::percent_format()) +
# 축, 제목, 범례 레이블 설정
labs(
title = "성별에 따른 임금 차별 발생 빈도 인식",
subtitle = "동일한 일을 하고도 여성이 남성보다 적은 임금을 받는 경우",
x = "응답자 성별",
y = "비율 (%)",
fill = "응답 범주"
) +
theme_minimal() +
theme(
text = element_text(family = "Malgun Gothic"), # Mac 사용자는 "AppleGothic"
plot.title = element_text(face = "bold", size = 15, hjust = 0.5),
plot.subtitle = element_text(size = 11, hjust = 0.5, color = "gray40"),
legend.position = "right", # 범례를 오른쪽에 배치
axis.text = element_text(size = 11)
)
# 2. 100% Stacked Bar Graph (누적 막대 그래프) 시각화
