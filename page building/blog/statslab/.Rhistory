summary_df <- kgss_svy %>%
filter(sexrole1 > 0) %>%
group_by(sex_label, age_group, year) %>%
summarise(
# sexrole1 값이 1, 2, 3 중 하나일 확률(비율)을 계산합니다.
# 결과 변수명을 직관적으로 _agree로 변경했습니다.
sexrole1_agree = survey_mean(sexrole1 %in% c(1, 2, 3), na.rm = TRUE)
)
# 확인을 위해 요약 데이터 출력 (결과값은 0 ~ 1 사이의 소수로 나옵니다)
