library(dplyr)
library(ggplot2)
library(tidyr)
library(marginaleffects)
library(modelsummary)
library(kableExtra)
library(gridExtra)
library(patchwork)
set.seed(42)
install.packages("tinytable")
library(dplyr)
library(ggplot2)
library(tidyr)
library(marginaleffects)
library(modelsummary)
library(kableExtra)
library(gridExtra)
library(patchwork)
set.seed(42)
n <- 800
d1 <- data.frame(
age    = runif(n, 25, 75),
income = pmax(rnorm(n, mean = 4.5, sd = 2), 0.5)   # income in $10k
) %>%
mutate(
srh = 3.5 +
0.080 * income +
-0.010 * age +
0.002 * income * age +          # true interaction
rnorm(n, 0, 0.5)
)
# ── Models ─────────────────────────────────────────────────────────────────
m1_no_int <- lm(srh ~ income + age,             data = d1)
m1_int    <- lm(srh ~ income * age,             data = d1)
library(tinytable)
library(tinytable)
# ── Regression Table ────────────────────────────────────────────────────────
modelsummary(
list("No Interaction" = m1_no_int,
"With Interaction" = m1_int),
stars   = c("*" = 0.05, "**" = 0.01, "***" = 0.001),
gof_map = c("nobs", "r.squared"),
coef_rename = c(
"(Intercept)" = "Intercept",
"income"      = "Income ($10k)",
"age"         = "Age",
"income:age"  = "Income × Age"
),
title = "OLS Regression: Self-Rated Health ~ Income × Age"
)
